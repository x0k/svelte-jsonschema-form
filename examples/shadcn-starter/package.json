{
  "name": "shadcn-starter",
  "version": "0.0.19",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite dev",
    "preview": "vite preview",
    "prepare": "svelte-kit sync || echo ''",
    "check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
    "check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
    "format": "oxfmt .",
    "format:check": "oxfmt --check ."
  },
  "dependencies": {
    "@internationalized/date": "catalog:legacy",
    "@lucide/svelte": "catalog:",
    "@sjsf/ajv8-validator": "workspace:*",
    "@sjsf/basic-theme": "workspace:*",
    "@sjsf/form": "workspace:*",
    "@sjsf/shadcn-theme": "workspace:*",
    "ajv": "catalog:",
    "bits-ui": "catalog:",
    "clsx": "catalog:shadcn",
    "tailwind-merge": "^2.6.0",
    "tailwind-variants": "^0.3.0",
    "tailwindcss-animate": "catalog:legacy"
  },
  "devDependencies": {
    "autoprefixer": "catalog:",
    "postcss": "catalog:",
    "svelte": "catalog:",
    "tailwindcss": "catalog:legacy"
  }
}
