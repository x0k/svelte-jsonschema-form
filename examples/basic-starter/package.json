{
  "name": "basic-starter",
  "version": "0.0.18",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite dev",
    "preview": "vite preview",
    "prepare": "svelte-kit sync || echo ''",
    "check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
    "check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
    "format": "oxfmt .",
    "format:check": "oxfmt --check ."
  },
  "dependencies": {
    "@sjsf/ajv8-validator": "workspace:*",
    "@sjsf/basic-theme": "workspace:*",
    "@sjsf/form": "workspace:*",
    "@sjsf/valibot-validator": "workspace:*",
    "@sjsf/zod4-validator": "workspace:*",
    "ajv": "catalog:",
    "ajv-formats": "catalog:",
    "ajv-i18n": "catalog:",
    "arktype": "catalog:",
    "json-schema-typed": "catalog:",
    "svelte": "catalog:",
    "svelte-exmarkdown": "catalog:",
    "typebox": "catalog:",
    "valibot": "catalog:",
    "zod": "catalog:"
  },
  "devDependencies": {
    "json-schema-to-ts": "catalog:"
  }
}
