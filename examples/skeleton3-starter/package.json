{
	"name": "skeleton3-starter",
	"private": true,
	"version": "0.0.17",
	"type": "module",
	"scripts": {
		"dev": "vite dev",
		"preview": "vite preview",
		"prepare": "svelte-kit sync || echo ''",
		"check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
		"check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch"
	},
	"devDependencies": {
		"@skeletonlabs/skeleton": "catalog:legacy",
		"@skeletonlabs/skeleton-svelte": "catalog:legacy",
		"@tailwindcss/forms": "catalog:",
		"@tailwindcss/vite": "catalog:",
		"svelte": "catalog:",
		"tailwindcss": "catalog:"
	},
	"dependencies": {
		"@sjsf/ajv8-validator": "workspace:*",
		"@sjsf/basic-theme": "workspace:*",
		"@sjsf/form": "workspace:*",
		"@sjsf/skeleton3-theme": "workspace:*",
		"ajv": "catalog:"
	}
}
