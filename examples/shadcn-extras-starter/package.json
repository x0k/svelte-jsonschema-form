{
  "name": "shadcn-extras-starter",
  "version": "0.0.17",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite dev",
    "preview": "vite preview",
    "prepare": "svelte-kit sync || echo ''",
    "check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
    "check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
    "format": "oxfmt .",
    "format:check": "oxfmt --check ."
  },
  "dependencies": {
    "@sjsf-lab/shadcn-extras-theme": "workspace:*",
    "@sjsf/ajv8-validator": "workspace:*",
    "@sjsf/basic-theme": "workspace:*",
    "@sjsf/form": "workspace:*",
    "@sjsf/shadcn4-theme": "workspace:*",
    "@zxcvbn-ts/core": "catalog:shadcn",
    "@zxcvbn-ts/language-common": "catalog:shadcn",
    "@zxcvbn-ts/language-en": "catalog:shadcn",
    "ajv": "catalog:",
    "bits-ui": "catalog:",
    "clsx": "catalog:shadcn",
    "country-flag-icons": "catalog:shadcn",
    "runed": "catalog:shadcn",
    "svelte-tel-input": "catalog:shadcn",
    "svelte-toolbelt": "catalog:shadcn",
    "yeezy-dates": "catalog:shadcn"
  },
  "devDependencies": {
    "@tailwindcss/vite": "catalog:",
    "svelte": "catalog:",
    "tailwind-merge": "catalog:shadcn",
    "tailwind-variants": "catalog:shadcn",
    "tailwindcss": "catalog:",
    "tw-animate-css": "catalog:shadcn",
    "vite": "catalog:"
  }
