  "src/routessjsf.svelte": "<script lang="ts">
	import * as defaults from 'src/lib/sjsf/defaults';
	import type { Post } from 'src/lib/post/model.generated';
	import { schema } from 'src/lib/post/model.generated';
	import * as validateFunctions from 'src/lib/post/validators.generated';
	import { createFormValidatorFactory } from '@sjsf/ajv8-validator/precompile';
	import { fromValidators } from '@sjsf/form/validators/precompile';
	import { BasicForm, createForm } from '@sjsf/form';

	const form = createForm<Post>({
		...defaults,
		onSubmit: console.log,
		schema,
		validator: createFormValidatorFactory({ validatorRetriever: fromValidators(validateFunctions) })
	});
</script>

<BasicForm form={form} novalidate />
