  "src/routes/demo/sjsf/+page.svelte": "<script lang="ts">
	import * as defaults from '$lib/sjsf/defaults';
	import { createPost, getInitialData } from './data.remote';
	import { connect } from '@sjsf/sveltekit/rf/client';
	import type { Post } from '$lib/post/model.generated';
	import { schema } from '$lib/post/model.generated';
	import * as validateFunctions from '$lib/post/validators.generated';
	import { createFormValidatorFactory } from '@sjsf/ajv8-validator/precompile';
	import { fromValidators } from '@sjsf/form/validators/precompile';
	import { BasicForm, createForm } from '@sjsf/form';

	const initialData = await getInitialData();

	const form = createForm<Post>(await connect(
		createPost.enhance(async ({ submit }) => {
			if (await submit()) {
				console.log(createPost.result);
				form.reset();
			}
		}),
		{
			...defaults,
			...initialData,
			fields: createPost.fields,
			validator: createFormValidatorFactory({ validatorRetriever: fromValidators(validateFunctions) })
		}
	));
</script>

<BasicForm form={form} novalidate />
",
  "src/routes/demo/sjsf/data.remote.ts": "import type { InitialFormData } from "@sjsf/sveltekit";
import { createServerValidator } from "@sjsf/sveltekit/rf/server";
import { form, query } from "$app/server";
import { fromValidators } from "@sjsf/form/validators/precompile";
import { createFormValidatorFactory } from "@sjsf/ajv8-validator/precompile";
import * as validateFunctions from "$lib/post/validators.generated";
import { schema } from "$lib/post/model.generated";
import type { Post } from "$lib/post/model.generated";
import * as defaults from "$lib/sjsf/defaults";

export const getInitialData = query(async () => {
	return ({ schema, initialValue: { title: "New post", content: "" } }) satisfies InitialFormData<Post>;
});

export const createPost = form(
	createServerValidator<Post>({
		...defaults,
		schema,
		validator: createFormValidatorFactory({ validatorRetriever: fromValidators(validateFunctions) })
	}),
	({ data }) => {
		console.log(data);

		return { ...data, id: "new-post" };
	}
);
",
  "src/routes/layout.css": "@import "@sjsf/basic-theme/css/basic.css";
",
