  "src/routes/demo/sjsf/+page.server.ts": "import type { Actions } from "@sveltejs/kit";
import type { InitialFormData } from "@sjsf/sveltekit";
import { createAction } from "@sjsf/sveltekit/server";
import { schema } from "$lib/post";
import type { Post } from "$lib/post";
import * as defaults from "$lib/sjsf/defaults";

export const load = async () => {
	return {
		postForm: ({ schema, initialValue: { title: "New post", content: "" } }) satisfies InitialFormData<Post>
	};
};

export const actions = ({
	default: createAction({ ...defaults, name: "postForm", sendData: true, schema }, (data: Post) => {
		console.log(data);

		return { post: { ...data, id: "new-post" } };
	})
}) satisfies Actions;
