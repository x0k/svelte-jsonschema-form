  "src/routes/demo/sjsf/+page.svelte": "<script lang="ts">
	import * as defaults from '$lib/sjsf/defaults';
	import type { Post } from '$lib/post/model.generated';
	import { schema } from '$lib/post/model.generated';
	import * as validateFunctions from '$lib/post/validators.generated';
	import { createFormValidatorFactory } from '@sjsf/schemasafe-validator/precompile';
	import { fromValidators } from '@sjsf/form/validators/precompile';
