  "src/routes/demo/sjsf/+page.svelte": "<script lang="ts">
	import * as defaults from '$lib/sjsf/defaults';
	import type { Post } from '$lib/post/model.generated';
	import { ast, schema } from '$lib/post/model.generated';
	import { localization } from '@sjsf-lab/hyperjump-validator/localizations/en-us';
	import { createFormValidatorFactory } from '@sjsf-lab/hyperjump-validator/precompile';
	import { createValidatorRetriever } from '@sjsf/form/validators/precompile';
	import { BasicForm, createForm } from '@sjsf/form';

	const form = createForm<Post>({
		...defaults,
		onSubmit: console.log,
		schema,
		validator: createFormValidatorFactory({
			validatorRetriever: createValidatorRetriever({
				registry: {
					get(id) {
						const schemaUri = \`\${id}#\`;

						return schemaUri in ast ? { schemaUri, ast } : undefined;
					}
				}
			}),
			localization
		})
	});
</script>

<BasicForm form={form} novalidate />
