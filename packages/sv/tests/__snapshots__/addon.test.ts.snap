  "src/routessjsf.svelte": "<script lang="ts">
	import * as defaults from 'src/lib/sjsf/defaults';
	import * as z from 'zod';
	import { post } from 'src/lib/post';
	import { adapt } from '@sjsf/zod4-validator/classic';
	import { BasicForm, createForm } from '@sjsf/form';

	const form = createForm({ ...defaults, onSubmit: console.log, ...adapt(post) });
</script>

<BasicForm form={form} novalidate />
",
