  "src/routes/demo/sjsf/+page.svelte": "<script lang="ts">
	import * as defaults from '$lib/sjsf/defaults';
	import { createPost, getInitialData } from './data.remote';
	import { connect } from '@sjsf/sveltekit/rf/client';
	import type { Post } from '$lib/post';
	import { schema } from '$lib/post';
	import { BasicForm, createForm } from '@sjsf/form';

	const initialData = await getInitialData();

	const form = createForm<Post>(await connect(
		createPost.enhance(async ({ submit }) => {
			if (await submit()) {
				console.log(createPost.result);
				form.reset();
			}
		}),
		{ ...defaults, ...initialData, fields: createPost.fields }
	));
</script>

<BasicForm form={form} novalidate />
