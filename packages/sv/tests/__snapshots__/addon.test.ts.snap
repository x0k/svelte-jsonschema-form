  "src/routes/demo/sjsf/+page.server.ts": "import type { Actions } from "@sveltejs/kit";
import type { InitialFormData } from "@sjsf/sveltekit";
import { createAction } from "@sjsf/sveltekit/server";
import { adapt } from "@sjsf/zod4-validator/classic";
import { post } from "$lib/post";
import * as z from "zod";
import * as defaults from "$lib/sjsf/defaults";

export const load = async () => {
	return {
		postForm: ({ initialValue: { title: "New post", content: "" } }) satisfies InitialFormData<z.infer<typeof post>>
	};
};

export const actions = ({
	default: createAction(
		{
			...defaults,
			name: "postForm",
			sendData: true,
			...adapt(post)
		},
		(data) => {
			console.log(data);

			return { post: { ...data, id: "new-post" } };
		}
	)
}) satisfies Actions;
",
  "src/routes/demo/sjsf/+page.svelte": "<script lang="ts">
	import * as defaults from '$lib/sjsf/defaults';
	import type { ActionData, PageData } from './$types';
	import { createMeta, setupSvelteKitForm } from '@sjsf/sveltekit/client';
	import { post } from '$lib/post';
	import { adapt } from '@sjsf/zod4-validator/classic';
	import { BasicForm } from '@sjsf/form';

	const meta = createMeta<ActionData, PageData>().postForm;

	const { form } = setupSvelteKitForm(meta, {
		...defaults,
		onSuccess: (result) => {
			if (result.type === "success") {
				console.log(result.data?.post);
			}
		},
		...adapt(post)
	});
</script>

<BasicForm form={form} method="POST" novalidate />
