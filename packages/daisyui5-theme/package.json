{
  "name": "@sjsf/daisyui5-theme",
  "version": "3.6.0",
  "description": "The daisyUI v5 based theme for svelte-jsonschema-form",
  "keywords": [
    "daisyUI",
    "form",
    "theme"
  ],
  "homepage": "https://x0k.github.io/svelte-jsonschema-form/",
  "bugs": "https://github.com/x0k/svelte-jsonschema-form/issues",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/x0k/svelte-jsonschema-form.git",
    "directory": "packages/daisyui5-theme"
  },
  "files": [
    "dist",
    "!dist/**/*.test.*",
    "!dist/**/*.spec.*"
  ],
  "type": "module",
  "types": "./dist/index.d.ts",
  "svelte": "./dist/index.js",
  "exports": {
    "./package.json": "./package.json",
    "./components/*": {
      "types": "./dist/components/*.d.ts",
      "svelte": "./dist/components/*"
    },
    "./widgets/*": {
      "types": "./dist/widgets/*.d.ts",
      "svelte": "./dist/widgets/*"
    },
    "./extra-widgets/*": {
      "types": "./dist/extra-widgets/*.d.ts",
      "svelte": "./dist/extra-widgets/*"
    },
    ".": {
      "types": "./dist/index.d.ts",
      "svelte": "./dist/index.js"
    },
    "./styles.css": "./dist/styles.css",
    "./specs": {
      "types": "./dist/specs.d.ts",
      "svelte": "./dist/specs.js"
    }
  },
  "publishConfig": {
    "provenance": true
  },
  "scripts": {
    "dev": "vite dev",
    "build": "svelte-package && vite build && mv $(find .svelte-kit/output/server/_app/immutable/assets/ -name \"_page*.css\" | head -n 1) dist/styles.css && ../../scripts/validate-theme-css.sh && publint",
    "preview": "vite preview",
    "test": "npm run test:unit -- --run",
    "test:visual": "vitest --project vrt",
    "check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
    "check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
    "lint": "eslint .",
    "test:integration": "playwright test",
    "test:unit": "vitest",
    "format": "oxfmt .",
    "format:check": "oxfmt --check ."
  },
  "dependencies": {
    "@sjsf/basic-theme": "workspace:^3.6.0"
  },
  "devDependencies": {
    "@sjsf/ajv8-validator": "workspace:*",
    "@sjsf/form": "workspace:*",
    "@sveltejs/svelte-json-tree": "catalog:",
    "@tailwindcss/vite": "catalog:",
    "@types/pikaday": "catalog:",
    "ajv": "catalog:",
    "cally": "catalog:",
    "daisyui": "catalog:",
    "globals": "catalog:",
    "pikaday": "catalog:",
    "svelte": "catalog:",
    "tailwindcss": "catalog:",
    "theme-testing": "workspace:*",
    "vanilla-calendar-pro": "catalog:"
  },
  "peerDependencies": {
    "@sjsf/form": "workspace:^3.5.0",
    "cally": "^0.8.0 || ^0.9.0",
    "daisyui": "^5.4.0",
    "pikaday": "^1.8.2",
    "svelte": "^5.34.8",
    "vanilla-calendar-pro": "^3.0.0"
  },
  "peerDependenciesMeta": {
    "cally": {
      "optional": true
    },
    "pikaday": {
      "optional": true
    },
    "vanilla-calendar-pro": {
      "optional": true
    }
  }
}
