{
  "name": "@sjsf/cfworker-validator",
  "version": "3.6.0",
  "description": "The @cfworker/json-schema based validator for svelte-jsonschema-form",
  "keywords": [
    "@cfworker/json-schema",
    "jsonschema",
    "validator"
  ],
  "homepage": "https://x0k.github.io/svelte-jsonschema-form/",
  "bugs": "https://github.com/x0k/svelte-jsonschema-form/issues",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/x0k/svelte-jsonschema-form.git",
    "directory": "packages/cfworker-validator"
  },
  "files": [
    "dist",
    "!dist/**/*.test.*",
    "!dist/**/*.spec.*"
  ],
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    "./package.json": "./package.json",
    ".": {
      "types": "./dist/index.d.ts",
      "svelte": "./dist/index.js"
    }
  },
  "publishConfig": {
    "provenance": true
  },
  "scripts": {
    "test": "vitest run",
    "build": "tsc && publint",
    "dev": "tsc --watch",
    "lint": "eslint ."
  },
  "devDependencies": {
    "@cfworker/json-schema": "catalog:",
    "@sjsf/form": "workspace:*",
    "svelte": "catalog:",
    "validator-testing": "workspace:*"
  },
  "peerDependencies": {
    "@cfworker/json-schema": "^4.1.0",
    "@sjsf/form": "workspace:^3.5.0"
  }
}
