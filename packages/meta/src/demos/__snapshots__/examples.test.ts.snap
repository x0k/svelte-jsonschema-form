  "src/routes/form.svelte": "<script lang="ts">
  import {
    createForm,
    BasicForm,
    type Schema,
    type UiSchemaRoot,
  } from "@sjsf/form";

  import * as defaults from "$lib/sjsf/defaults";

  import StoredFileField from "./stored-file-field.svelte";
  import { setStoreContext } from "./context";

  const {
    initialValue,
    onFileCreated,
  }: {
    initialValue?: { file: string };
    onFileCreated?: (key: string) => void;
  } = $props();

  const schema = {
    type: "object",
    title: "File form",
    properties: {
      file: {
        title: "File",
        type: "string",
      },
    },
    required: ["file"],
  } as const satisfies Schema;

  const uiSchema: UiSchemaRoot = {
    file: {
      "ui:components": {
        stringField: StoredFileField,
      },
    },
  };

