              title: "Other Label",
              minLength: 3,
            },
          },
          required: ["otherField"],
        },
        {
          title: "Page 1.3",
          type: "object",
          properties: {
            number: {
              type: "number",
              title: "Some number",
              minimum: 5,
              maximum: 150,
            },
          },
          required: ["number"],
        },
      ],
