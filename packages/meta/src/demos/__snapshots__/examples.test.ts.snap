	import * as v from "valibot";
	import { adapt } from "@sjsf/valibot-validator";
	import { extendByRecord } from "@sjsf/form/lib/resolver";

	import {
		createForm,
		BasicForm,
		type Schema,
		type FormState,
		type ResolveFieldType,
		getValueSnapshot
	} from "@sjsf/form";

	import * as defaults from "$lib/sjsf/defaults";
	import nullableField, { isNullableField } from "./nullable-field.svelte";

	const schema = v.object({
		"foo": v.union([v.string(), v.null_()]),
		"bar": v.optional(v.union([v.null_(), v.number()])),
		"baz": v.optional(v.union([v.object({ "hello": v.optional(v.boolean()) }), v.null_()]))
	});

	function resolver<T>(ctx: FormState<T>): ResolveFieldType {
		const resolve = defaults.resolver(ctx);

		return (config) => {
			if (isNullableField(config.schema)) {
				return "nullableField";
			}

			return resolve(config);
		};
	}

	const form = createForm({
		...defaults,
		theme: extendByRecord(defaults.theme, { nullableField }),
		resolver,
		...adapt(schema),
		onSubmit: console.log
	});
