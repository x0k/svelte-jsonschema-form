  const Form = $derived(subTabs ? SubTabs : TopTabs);
</script>

<label style="display: flex; justify-items: baseline; gap: 0.2rem; padding-block: 1rem" >
  <input type="checkbox" bind:checked={subTabs} />
  Sub tabs
</label>

<Form />
