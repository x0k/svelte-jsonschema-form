                  const snap = getValueSnapshot(form)
                  const step = isRecord(snap) && snap[STEP_KEY]
                  return \`display: \${
                    config.path[0] === step ? "block" : "none"
                  }\`;
                },
              },
            }
          : undefined,
    }),
  });
  setFormContext(form);
