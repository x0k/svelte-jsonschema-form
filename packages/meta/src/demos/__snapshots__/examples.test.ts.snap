{
  "package.json": "{
  "name": "async-combobox",
  "version": "0.0.1",
  "type": "module",
  "dependencies": {
    "@sjsf/form": "^3.5.0",
    "@sjsf/basic-theme": "^3.6.0",
    "svelte": "^5.34.8",
    "@sjsf-lab/ata-validator": "^3.1.1",
    "ata-validator": "^0.13.3"
