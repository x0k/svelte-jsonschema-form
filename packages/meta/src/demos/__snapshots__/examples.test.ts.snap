  "src/routes/[id]/+page.svelte": "<script lang="ts">
  import { BasicForm, createForm } from "@sjsf/form";
  import { connect } from "@sjsf/sveltekit/rf/client";

  import { page } from '$app/state'

  import * as defaults from "$lib/sjsf/defaults";

