  "src/lib/server.ts": "import type { Schema } from "@sjsf/form";

const schemas: Record<string, Schema> = {
  foo: {
    type: "object",
    properties: {
      foo: {
        type: "string",
        minLength: 8
      },
    },
    required: ["foo"],
  },
