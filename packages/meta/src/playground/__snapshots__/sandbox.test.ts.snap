exports[`sandbox-factory > form > fieldsValidationMode 1`] = `
{
  "package.json": "{
  "name": "sandbox",
  "version": "0.0.1",
  "type": "module",
  "dependencies": {
    "@sjsf/form": "^3.5.0",
    "@sveltejs/kit": "^2.48.3",
    "svelte": "^5.34.8",
    "@sjsf/basic-theme": "^3.7.0",
    "@sjsf/schemasafe-validator": "^3.7.0",
    "@exodus/schemasafe": "^1.3.0"
  },
  "devDependencies": {
    "vite": "^8.1.2",
    "@sveltejs/adapter-auto": "^7.0.1",
    "@sveltejs/vite-plugin-svelte": "^7.1.2",
    "typescript": "^6.0.3",
    "esm-env": "^1.2.0",
    "json-schema-to-ts": "^3.1.1"
  },
  "scripts": {
    "dev": "vite dev",
    "sjsf:compile": "node scripts/compile-validators.ts",
    "prepare": "npm run sjsf:compile"
  }
}",
  "scripts/compile-validators.ts": "import fs from "node:fs/promises";
import path from "node:path";
import { ON_INPUT, ON_CHANGE } from "@sjsf/form";
import { convert } from "@sjsf/form/converters/draft-2020-12";
import { insertSubSchemaIds, fragmentSchema } from "@sjsf/form/validators/precompile";
import { validator } from "@exodus/schemasafe";
import { DEFAULT_VALIDATOR_OPTIONS, FORM_FORMATS } from "@sjsf/schemasafe-validator";

const FIELDS_VALIDATION = { ON_INPUT, ON_CHANGE };
const FIELDS_VALIDATION_KEYS = Object.keys(FIELDS_VALIDATION).join(", ");
const FIELDS_VALIDATION_MODE = Object.keys(FIELDS_VALIDATION).join(" | ");
const FIELDS_VALIDATION_MODE_VALUE = Object.values(FIELDS_VALIDATION).reduce((a, b) => a | b, 0);
const MODEL_PATHS = ["src/lib/model/"];
const SCRIPT_PATH = path.relative(process.cwd(), import.meta.filename);

async function readJson(dir: string, file: string) {
	const filePath = path.join(dir, file);

	try {
		await fs.access(filePath);

		return JSON.parse(await fs.readFile(filePath, "utf-8"));
	} catch {
		return null;
	}
}

async function compileSchema(modelDirRelPath: string) {
	const modelDir = path.resolve(modelDirRelPath);
	const schema = await readJson(modelDir, "schema.json");

	if (!schema) {
		throw new Error(\`schema.json file not found in "\${modelDir}" directory\`);
	}

	const uiSchema = await readJson(modelDir, "ui-schema.json");
	const initialValue = await readJson(modelDir, "initial-value.json");
	const patch = insertSubSchemaIds(schema.$schema?.startsWith("https://json-schema.org/draft/2020-12/schema") ? convert(schema) : schema, { fieldsValidationMode: FIELDS_VALIDATION_MODE_VALUE });
	const schemas = fragmentSchema(patch);

	// It is easier to save as a TS file
	// https://github.com/microsoft/TypeScript/issues/32063
	await fs.writeFile(path.join(modelDir, "model.generated.ts"), \`// Generated by \${SCRIPT_PATH} - do not edit
import type { Schema, UiSchemaRoot } from "@sjsf/form";
import type { FromSchema } from "json-schema-to-ts";
import { \${FIELDS_VALIDATION_KEYS} } from "@sjsf/form";

export const fieldsValidationMode = \${FIELDS_VALIDATION_MODE};
export const schema = \${JSON.stringify(patch.schema, null, 2)} as const satisfies Schema;
export type Model = FromSchema<typeof schema>;
\${uiSchema
		? "\\nexport const uiSchema = " + JSON.stringify(uiSchema, null, 2) + " as const satisfies UiSchemaRoot;"
		: ""}\${initialValue
		? "\\nexport const initialValue = " + JSON.stringify(initialValue, null, 2) + ";"
		: ""}\`);

	// @ts-expect-error Typings for \`multi\` version are missing
	const validate = validator(schemas, {
		...DEFAULT_VALIDATOR_OPTIONS,
		formats: FORM_FORMATS,
		schemas: new Map(schemas.map((schema) => [schema.$id, schema])),
		multi: true
	});

	const validateFunctions = \`export const [\${schemas.map((s) => s.$id).join(", ")}] = \${validate.toModule()}\`;

	await fs.writeFile(path.join(modelDir, "validators.generated.js"), \`// @ts-nocheck\\n\${validateFunctions}\`);
}

async function main() {
	await Promise.all(MODEL_PATHS.map(compileSchema));
}

if (import.meta.main) {
	await main();
}",
