// https://x0k.dev/svelte-jsonschema-form/themes/shadcn4/#components
export function setShadcnThemeContext() {
	setThemeContext({
		components: {
			Button,
			FieldDescription,
			FieldError,
			FieldLabel,
			Field,
			FieldSet,
			FieldLegend,
			FieldGroup,
			FieldTitle,
