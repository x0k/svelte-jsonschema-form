// import "@sjsf/basic-theme/extra-widgets/multi-select-include";
// import "@sjsf/basic-theme/extra-widgets/radio-include";
export const theme = extendByRecord(base, { markdownDescription, transparentLayout });

export const onSubmitError = createFocusOnFirstError();

declare module "@sjsf/form" {
	interface ComponentProps { markdownDescription: description; transparentLayout: layout }
	interface ComponentBindings { markdownDescription: ""; transparentLayout: "" }
	interface UiOptionsRegistry { stringEnumValueMapper: EnumValueMapperBuilder }
}

export function validator<T>(options: ValidatorFactoryOptions) {
	return createFormValidator<T>({
		...options,
		ajvPlugins: (ajv) => addFormComponents(addFormats(ajv))
	});
}

export const uiOptionsRegistry = {
	stringEnumValueMapper: () => new StringEnumValueMapperBuilder()
};",
