  "src/lib/sjsf/shadcn.ts": "import {
	Button,
	FieldDescription,
	FieldError,
	FieldLabel,
	Field,
	FieldSet,
	FieldLegend,
	FieldGroup,
	FieldTitle,
	ButtonGroup,
	Checkbox,
	Input,
	Select,
	SelectTrigger,
	SelectContent,
	SelectItem
} from '@sjsf/shadcn4-theme/new-york';

import { setThemeContext } from '@sjsf/shadcn4-theme';

// https://x0k.dev/svelte-jsonschema-form/themes/shadcn4/#components
export function setShadcnThemeContext() {
	setThemeContext({
		components: {
			Button,
			FieldDescription,
			FieldError,
			FieldLabel,
			Field,
			FieldSet,
			FieldLegend,
			FieldGroup,
			FieldTitle,
