export { resolver } from "@sjsf/form/resolvers/basic";

export { translation } from "@sjsf/form/translations/en";

export function merger(options: FormMergerOptions) {
	return createFormMerger({
		...options,
		"allOf": "populateDefaults",
		"arrayMinItems": { "populate": "all", "mergeExtraDefaults": false },
		"constAsDefaults": "always",
		"emptyObjectFields": "skipDefaults",
		"mergeDefaultsIntoFormData": "useFormDataIfPresent"
	});
}

export { createFormIdBuilder as idBuilder } from "@sjsf/form/id-builders/modern";

