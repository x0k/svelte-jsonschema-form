  "src/lib/sjsf/shadcn.ts": "import {
	Button,
	FieldDescription,
	FieldError,
	FieldLabel,
	Field,
	FieldSet,
	FieldLegend,
	FieldGroup,
	FieldTitle,
	ButtonGroup,
	Checkbox,
	Input,
	Select,
	SelectTrigger,
	SelectContent,
	SelectItem
} from '@sjsf/shadcn4-theme/new-york';

import { setThemeContext } from '@sjsf/shadcn4-theme';

// https://x0k.dev/svelte-jsonschema-form/themes/shadcn4/#components
export function setShadcnThemeContext() {
	setThemeContext({
		components: {
			Button,
			FieldDescription,
			FieldError,
			FieldLabel,
			Field,
			FieldSet,
			FieldLegend,
			FieldGroup,
			FieldTitle,
			ButtonGroup,
			Checkbox,
			Input,
			Select,
			SelectTrigger,
			SelectContent,
			SelectItem

			// Popover,
			// PopoverContent,
			// PopoverTrigger,
			// Command,
			// CommandInput,
			// CommandList,
			// CommandEmpty,
			// CommandGroup,
			// CommandItem,
			// Calendar,
			// RangeCalendar,
			// ToggleGroup,
			// ToggleGroupItem,
			// RadioGroup,
			// RadioGroupItem,
			// Slider,
			// Switch,
			// Textarea
		}
	});
}",
  "src/routes/+layout.svelte": "<script lang="ts">
	import { setShadcnThemeContext } from '$lib/sjsf/shadcn';
	import './layout.css';
	import type { Snippet } from 'svelte';

	const { children }: { children: Snippet } = $props();

	setShadcnThemeContext();
</script>

<div style="padding: 2rem">{@render children()}</div>",
