	}
} as const satisfies UiSchemaRoot;;",
  "src/lib/sjsf/defaults.ts": "import { StringEnumValueMapperBuilder } from "@sjsf/form/options.svelte";
import addFormats from "ajv-formats";
import { addFormComponents, createFormValidator } from "@sjsf/ajv8-validator";

import type {
	ComponentProps,
	ComponentBindings,
	UiOptionsRegistry,
	ValidatorFactoryOptions
} from "@sjsf/form";

import { createFocusOnFirstError } from "@sjsf/form/focus-on-first-error";
import "@sjsf/basic-theme/extra-widgets/textarea-include";
import "@sjsf/basic-theme/extra-widgets/range-include";
import { markdownDescription, transparentLayout } from "$lib/custom-components";
import { theme as base } from "@sjsf/basic-theme";
import { extendByRecord } from "@sjsf/form/lib/resolver";
import "@sjsf/form/fields/extra/multi-enum-include";
import "@sjsf/form/fields/extra/enum-include";

// import "@sjsf/form/fields/extra/aggregated-include";
