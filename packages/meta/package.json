{
  "name": "meta",
  "version": "1.0.3",
  "license": "MIT",
  "private": true,
  "type": "module",
  "scripts": {
    "extract-fields": "node scripts/extract-fields.ts",
    "extract-widgets": "node scripts/extract-widgets.ts",
    "extract-packages": "node scripts/extract-packages.ts",
    "extract-metadata": "npm run extract-fields && npm run extract-widgets && npm run extract-packages",
    "check": "npm run extract-metadata && svelte-check --tsconfig ./tsconfig.json",
    "build": "svelte-package && publint"
  },
  "peerDependencies": {
    "@cfworker/json-schema": "catalog:",
    "@exodus/schemasafe": "catalog:",
    "@picocss/pico": "catalog:",
    "@stackblitz/sdk": "catalog:",
    "@sveltejs/acorn-typescript": "catalog:",
    "@types/estree": "catalog:",
    "@webcontainer/api": "catalog:",
    "acorn": "catalog:",
    "ajv": "catalog:",
    "ajv-formats": "catalog:",
    "ata-validator": "catalog:",
    "beercss": "catalog:",
    "json-schema-to-ts": "catalog:",
    "json-schema-to-valibot": "catalog:",
    "json-schema-to-zod": "catalog:",
    "lz-string": "catalog:",
    "svelte": "^5.34.8",
    "zimmerframe": "catalog:",
    "@sveltejs/sv-utils": "catalog:"
  },
  "dependencies": {
    "@sjsf-lab/ata-validator": "workspace:*",
    "@sjsf-lab/beercss-theme": "workspace:*",
    "@sjsf-lab/hyperjump-validator": "workspace:*",
    "@sjsf-lab/shadcn-extras-theme": "workspace:*",
    "@sjsf-lab/svar-theme": "workspace:*",
    "@sjsf/ajv8-validator": "workspace:*",
    "@sjsf/basic-theme": "workspace:*",
    "@sjsf/cfworker-validator": "workspace:*",
    "@sjsf/daisyui-theme": "workspace:*",
    "@sjsf/daisyui5-theme": "workspace:*",
    "@sjsf/flowbite-icons": "workspace:*",
    "@sjsf/flowbite-theme": "workspace:*",
    "@sjsf/flowbite3-theme": "workspace:*",
    "@sjsf/form": "workspace:*",
    "@sjsf/lucide-icons": "workspace:*",
    "@sjsf/moving-icons": "workspace:*",
    "@sjsf/radix-icons": "workspace:*",
    "@sjsf/schemasafe-validator": "workspace:*",
    "@sjsf/shadcn-theme": "workspace:*",
    "@sjsf/shadcn4-theme": "workspace:*",
    "@sjsf/skeleton3-theme": "workspace:*",
    "@sjsf/skeleton4-theme": "workspace:*",
    "@sjsf/sveltekit": "workspace:*",
    "@sjsf/valibot-validator": "workspace:*",
    "@sjsf/zod4-validator": "workspace:*"
  },
  "devDependencies": {
    "@cfworker/json-schema": "catalog:",
    "@exodus/schemasafe": "catalog:",
    "@picocss/pico": "catalog:",
    "@stackblitz/sdk": "catalog:",
    "@sveltejs/acorn-typescript": "catalog:",
    "@sveltejs/sv-utils": "catalog:",
    "@types/estree": "catalog:",
    "@typescript-eslint/types": "catalog:",
    "@webcontainer/api": "catalog:",
    "acorn": "catalog:",
    "ajv": "catalog:",
    "ajv-formats": "catalog:",
    "ata-validator": "catalog:",
    "beercss": "catalog:",
    "json-schema-to-valibot": "catalog:",
    "json-schema-to-zod": "catalog:",
    "lz-string": "catalog:",
    "svelte": "catalog:",
    "yaml": "^2.8.3",
    "zimmerframe": "catalog:"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./playground": {
      "types": "./dist/playground/index.d.ts",
      "default": "./dist/playground/index.js"
    },
    "./playground/augmentations": {
      "types": "./dist/playground/augmentations.d.ts",
      "default": "./dist/playground/augmentations.js"
    },
    "./playground/form-presets/*": {
      "types": "./dist/playground/form-presets/*.d.ts",
      "default": "./dist/playground/form-presets/*.js"
    },
    "./composer": {
      "types": "./dist/composer/index.d.ts",
      "default": "./dist/composer/index.js"
    },
    "./codegen": {
      "types": "./dist/codegen/index.d.ts",
      "default": "./dist/codegen/index.js"
    },
    "./builder": {
      "types": "./dist/builder/index.d.ts",
      "default": "./dist/builder/index.js"
    }
  }
}
