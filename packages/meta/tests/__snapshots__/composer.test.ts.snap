// https://x0k.dev/svelte-jsonschema-form/guides/fields-resolution/
export function resolver<T>(_ctx: FormState<T>): ResolveFieldType {
	return ({ schema }) => {
		if (schema.oneOf !== undefined) {
			return "oneOfField";
		}

