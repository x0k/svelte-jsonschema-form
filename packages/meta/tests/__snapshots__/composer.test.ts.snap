  "src/routes/data.remote.ts": "import type { InitialFormData } from "@sjsf/sveltekit";
import { createServerValidator } from "@sjsf/sveltekit/rf/server";
import { form, query } from "$app/server";
import { schema } from "$lib/post";
import type { Post } from "$lib/post";
import * as defaults from "$lib/sjsf/defaults";

export const getInitialData = query(async () => {
	return ({ schema, initialValue: { title: "New post", content: "" } }) satisfies InitialFormData<Post>;
