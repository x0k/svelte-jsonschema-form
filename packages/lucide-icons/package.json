{
  "name": "@sjsf/lucide-icons",
  "version": "3.6.0",
  "description": "The lucide based icons set for svelte-jsonschema-form",
  "keywords": [
    "form",
    "icons",
    "lucide"
  ],
  "homepage": "https://x0k.github.io/svelte-jsonschema-form/",
  "bugs": "https://github.com/x0k/svelte-jsonschema-form/issues",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/x0k/svelte-jsonschema-form.git",
    "directory": "packages/lucide-icons"
  },
  "files": [
    "dist",
    "!dist/**/*.test.*",
    "!dist/**/*.spec.*"
  ],
  "type": "module",
  "types": "./dist/index.d.ts",
  "svelte": "./dist/index.js",
  "exports": {
    "./package.json": "./package.json",
    ".": {
      "types": "./dist/index.d.ts",
      "svelte": "./dist/index.js"
    },
    "./extra/*": {
      "types": "./dist/extra/*.d.ts",
      "svelte": "./dist/extra/*"
    }
  },
  "publishConfig": {
    "provenance": true
  },
  "scripts": {
    "dev": "vite dev",
    "build": "svelte-package && publint",
    "preview": "vite preview",
    "test": "npm run test:unit -- --run",
    "check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
    "check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
    "lint": "eslint .",
    "test:integration": "playwright test",
    "test:unit": "vitest",
    "format": "oxfmt .",
    "format:check": "oxfmt --check ."
  },
  "devDependencies": {
    "@lucide/svelte": "catalog:",
    "@sjsf/form": "workspace:*",
    "globals": "catalog:",
    "svelte": "catalog:",
    "theme-testing": "workspace:*"
  },
  "peerDependencies": {
    "@lucide/svelte": ">=0.479.0 <1.0.0 || ^1.0.0",
    "@sjsf/form": "workspace:^3.5.0",
    "svelte": "^5.34.8"
  }
}
