{
  "name": "@sjsf/flowbite-icons",
  "version": "3.6.0",
  "description": "The flowbite based icons set for svelte-jsonschema-form",
  "keywords": [
    "flowbite",
    "form",
    "icons"
  ],
  "homepage": "https://x0k.github.io/svelte-jsonschema-form/",
  "bugs": "https://github.com/x0k/svelte-jsonschema-form/issues",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/x0k/svelte-jsonschema-form.git",
    "directory": "packages/flowbite-icons"
  },
  "files": [
    "dist",
    "!dist/**/*.test.*",
    "!dist/**/*.spec.*"
  ],
  "type": "module",
  "types": "./dist/index.d.ts",
  "svelte": "./dist/index.js",
  "exports": {
    "./package.json": "./package.json",
    ".": {
      "types": "./dist/index.d.ts",
      "svelte": "./dist/index.js"
    },
    "./preset": {
      "types": "./dist/preset.d.ts",
      "default": "./dist/preset.js"
    },
    "./extra/*": {
      "types": "./dist/extra/*.d.ts",
      "svelte": "./dist/extra/*"
    },
    "./styles.css": "./dist/styles.css"
  },
  "publishConfig": {
    "provenance": true
  },
  "scripts": {
    "dev": "vite dev",
    "build": "svelte-package && vite build && mv $(find .svelte-kit/output/server/_app/immutable/assets/ -name \"_page*.css\" | head -n 1) dist/styles.css && publint",
    "preview": "vite preview",
    "test": "npm run test:unit -- --run",
    "check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
    "check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
    "lint": "eslint .",
    "test:integration": "playwright test",
    "test:unit": "vitest",
    "format": "oxfmt .",
    "format:check": "oxfmt --check ."
  },
  "devDependencies": {
    "@sjsf/form": "workspace:*",
    "@tailwindcss/vite": "catalog:",
    "flowbite-svelte-icons": "^3.1.0",
    "globals": "catalog:",
    "svelte": "catalog:",
    "tailwindcss": "catalog:",
    "theme-testing": "workspace:*"
  },
  "peerDependencies": {
    "@sjsf/form": "workspace:^3.5.0",
    "flowbite-svelte-icons": "^3.0.0",
    "svelte": "^5.34.8",
    "tailwind-merge": "^3.3.0"
  }
}
