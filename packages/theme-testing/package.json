{
  "name": "theme-testing",
  "version": "1.0.27",
  "private": true,
  "license": "(MIT AND Apache-2.0)",
  "type": "module",
  "exports": {
    "./demo": {
      "types": "./dist/demo/index.d.ts",
      "svelte": "./dist/demo/index.js"
    },
    "./snapshots/*": {
      "types": "./dist/snapshots/*.d.ts",
      "default": "./dist/snapshots/*.js"
    },
    "./fields/*": {
      "types": "./dist/fields/*.d.ts",
      "default": "./dist/fields/*.js"
    },
    "./specs": {
      "types": "./dist/specs/index.d.ts",
      "default": "./dist/specs/index.js"
    }
  },
  "scripts": {
    "build": "svelte-package && publint",
    "check": "svelte-check --tsconfig ./tsconfig.json",
    "lint": "eslint .",
    "format": "oxfmt .",
    "format:check": "oxfmt --check ."
  },
  "dependencies": {
    "@sjsf/ajv8-validator": "workspace:*",
    "@sjsf/form": "workspace:*",
    "@sveltejs/svelte-json-tree": "^2.2.1",
    "ajv": "catalog:"
  },
  "devDependencies": {
    "svelte": "catalog:"
  },
  "peerDependencies": {
    "svelte": "^5.34.8"
  }
}
