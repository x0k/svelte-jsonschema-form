---
export interface TabItem {
  key: string;
  label: string;
  checked?: boolean;
}

export interface Props {
  tabs: TabItem[];
  sticky?: boolean;
}

const { tabs, sticky = false } = Astro.props;

const styles = `
  .static-tabs${sticky ? ".sticky" : ""} {
    z-index: 10;
    display: flex;
    flex-direction: row;
    flex-wrap: wrap;
    justify-content: center;
    gap: 0.5rem;${sticky ? "\n    position: sticky;\n    top: calc(64px + 1rem);" : ""}
  }${sticky ? `
  @media (min-width: 50rem) {
    .static-tabs.sticky {
      top: calc(64px + 48px + 1rem);
    }
  }
  @media (min-width: 72rem) {
    .static-tabs.sticky {
      top: calc(64px + 1rem);
    }
  }` : ""}
  .static-tab {
    min-width: fit-content;
    appearance: none;
    cursor: pointer;
    text-align: center;
    user-select: none;
    flex-wrap: wrap;
    justify-content: center;
    align-items: center;
    display: inline-flex;
    padding-inline: 1.25rem;
    padding-block: 0.15rem;
    border: 1px solid var(--sl-color-gray-5);
    border-radius: 999px;
    background-color: var(--sl-color-bg);
    transition: background 0.15s, color 0.15s, border-color 0.15s;
  }
  .static-tab:after {
    content: attr(aria-label);
  }
  .static-tab:checked {
    background-color: var(--sl-color-gray-5);
    border-color: var(--sl-color-text-accent);
    color: var(--sl-color-white);
  }
  [data-theme="light"] .static-tab:checked {
    background-color: var(--sl-color-bg);
  }
  .static-content-wrapper {
    width: 100%;
  }
  .static-content {
    display: none;
    width: 100%;
    order: 1;
    margin-top: 1rem;
  }
  ${tabs
    .map(
      (tab) => `
  .static-tabs:has(.static-tab[data-theme="${tab.key}"]:checked) ~ .static-content-wrapper .static-content[data-theme="${tab.key}"] {
    display: block;
    height: 100%;
  }`
    )
    .join("\n")}
`;
---

<div class:list={["static-tabs", { sticky }]}>
  {
    tabs.map((tab) => (
      <input
        type="radio"
        name="static-tabs-input"
        class="static-tab"
        aria-label={tab.label}
        checked={tab.checked}
        data-theme={tab.key}
      />
    ))
  }
</div>
<div class="static-content-wrapper">
  <slot />
</div>

<style set:html={styles}></style>
