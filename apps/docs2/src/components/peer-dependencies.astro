---
import type { Package } from 'meta'

interface Props {
  pkg: Package
  hideOptional?: boolean;
}

const {
  pkg,
  hideOptional = false,
} = Astro.props;

const required: string[] = []
const optional: string[] = []
for (const d of pkg.dependencies) {
  (d.optional ? optional : required).push(`${d.name}@${d.version}`)
}
---

{
  pkg.dependencies.length > 0 && (
    <div class="mt-4 border-t border-surface-100 dark:border-surface-800 pt-3 text-sm text-surface-500 dark:text-surface-400 leading-relaxed space-y-1">
      {required.length > 0 && (
        <p class="m-0">
          Required peer dependencies: <code>{required.join(" ")}</code>
        </p>
      )}

      {!hideOptional && optional.length > 0 && (
        <p class="m-0">
          Optional peer dependencies: <code>{optional.join(" ")}</code>
        </p>
      )}
    </div>
  )
}
