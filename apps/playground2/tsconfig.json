{
  "extends": "@total-typescript/tsconfig/bundler/dom/app",
  "compilerOptions": {
    "lib": ["ES2023"],
    "moduleResolution": "bundler",
    "module": "preserve",
    "rootDir": "src",
    "types": ["vite/client"],
    "paths": {
      "@/*": ["./src/*"],
      "$lib": ["./src/lib"],
      "$lib/*": ["./src/lib/*"]
    }
  },
  "include": ["src/**/*.ts", "src/**/*.js", "src/**/*.svelte"]
}
