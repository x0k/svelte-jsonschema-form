{
  "extends": "@total-typescript/tsconfig/bundler/dom/app",
  "compilerOptions": {
    "target": "esnext",
    "lib": [
      "ESNext"
    ],
    "noUncheckedIndexedAccess": false,
    "moduleResolution": "bundler",
    "module": "preserve",
    "types": [
      "vite/client"
    ],
    "baseUrl": ".",
    "paths": {
      "$lib": [
        "./src/lib"
      ],
      "$lib/*": [
        "./src/lib/*"
      ],
    }
  },
  "include": [
    "src/**/*.ts",
    "src/**/*.js",
    "src/**/*.svelte"
  ]
}