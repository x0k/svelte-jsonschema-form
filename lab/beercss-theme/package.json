{
  "name": "@sjsf-lab/beercss-theme",
  "version": "3.3.0",
  "description": "The Beer CSS v3 based theme for svelte-jsonschema-form",
  "keywords": [
    "beercss",
    "form",
    "theme"
  ],
  "homepage": "https://x0k.github.io/svelte-jsonschema-form/",
  "bugs": "https://github.com/x0k/svelte-jsonschema-form/issues",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/x0k/svelte-jsonschema-form.git",
    "directory": "lab/beercss-theme"
  },
  "files": [
    "dist",
    "!dist/**/*.test.*",
    "!dist/**/*.spec.*"
  ],
  "type": "module",
  "types": "./dist/index.d.ts",
  "svelte": "./dist/index.js",
  "exports": {
    "./package.json": "./package.json",
    "./components/*": {
      "types": "./dist/components/*.d.ts",
      "svelte": "./dist/components/*"
    },
    "./widgets/*": {
      "types": "./dist/widgets/*.d.ts",
      "svelte": "./dist/widgets/*"
    },
    "./extra-widgets/*": {
      "types": "./dist/extra-widgets/*.d.ts",
      "svelte": "./dist/extra-widgets/*"
    },
    ".": {
      "types": "./dist/index.d.ts",
      "svelte": "./dist/index.js"
    },
    "./specs": {
      "types": "./dist/specs.d.ts",
      "svelte": "./dist/specs.js"
    }
  },
  "publishConfig": {
    "provenance": true
  },
  "scripts": {
    "dev": "vite dev",
    "build": "svelte-package && publint",
    "preview": "vite preview",
    "test": "npm run test:unit -- --run",
    "test:visual": "vitest --project vrt",
    "check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
    "check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
    "lint": "eslint .",
    "test:integration": "playwright test",
    "test:unit": "vitest",
    "format": "oxfmt .",
    "format:check": "oxfmt --check ."
  },
  "dependencies": {
    "@sjsf/basic-theme": "workspace:^3.6.0"
  },
  "devDependencies": {
    "@sjsf/ajv8-validator": "workspace:*",
    "@sjsf/form": "workspace:*",
    "@sveltejs/svelte-json-tree": "catalog:",
    "@tailwindcss/vite": "catalog:",
    "ajv": "catalog:",
    "beercss": "catalog:",
    "globals": "catalog:",
    "svelte": "catalog:",
    "theme-testing": "workspace:*"
  },
  "peerDependencies": {
    "@sjsf/form": "workspace:^3.5.0",
    "beercss": "^3.13.0 || ^4.0.0",
    "svelte": "^5.34.8"
  }
}
