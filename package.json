{
  "name": "svelte-jsonschema-form",
  "version": "0.0.0",
  "private": true,
  "license": "MIT",
  "author": "Krasilnikov Roman",
  "type": "module",
  "scripts": {
    "preinstall": "npx only-allow pnpm",
    "check": "turbo run check",
    "dev": "turbo run dev",
    "test": "turbo run test",
    "build": "turbo run build --concurrency 12",
    "preview": "turbo run preview",
    "lint": "turbo run lint",
    "lint:fix": "turbo run lint -- --fix",
    "format": "oxfmt",
    "format:check": "oxfmt --check",
    "ci:build": "turbo run build test",
    "ci:version": "changeset version && pnpm install --no-frozen-lockfile && pnpm --filter @sjsf/sv run test -u"
  },
  "devDependencies": {
    "@changesets/changelog-git": "^0.2.1",
    "@changesets/cli": "2.31.0",
    "@eslint/js": "^10.0.1",
    "@playwright/test": "catalog:",
    "@sveltejs/adapter-auto": "catalog:",
    "@sveltejs/adapter-static": "^3.0.10",
    "@sveltejs/kit": "catalog:",
    "@sveltejs/package": "2.5.8",
    "@sveltejs/vite-plugin-svelte": "catalog:",
    "@svitejs/changesets-changelog-github-compact": "^1.2.0",
    "@total-typescript/tsconfig": "^1.0.4",
    "@types/node": "^25.9.2",
    "@vitest/browser": "^4.1.8",
    "@vitest/browser-playwright": "^4.1.8",
    "eslint": "^10.4.1",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-svelte": "^3.19.0",
    "globals": "catalog:",
    "only-allow": "^1.2.2",
    "oxfmt": "^0.54.0",
    "playwright": "catalog:",
    "publint": "^0.3.21",
    "svelte-check": "^4.6.0",
    "turbo": "^2.9.17",
    "typescript": "catalog:",
    "typescript-eslint": "^8.61.0",
    "vite": "catalog:",
    "vite-plugin-devtools-json": "^1.0.0",
    "vitest": "catalog:",
    "vitest-browser-svelte": "^2.1.1"
  },
  "packageManager": "pnpm@11.6.0"
}
